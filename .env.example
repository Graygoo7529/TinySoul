# TinySoul environment example.
# Copy this file to .env and fill at least one chat provider API key.

# Provider API keys
GLM_API_KEY=
ZHIPU_API_KEY=
KIMI_API_KEY=
MOONSHOT_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=

# Optional model overrides
GLM_MODEL=glm-4.7
GLM_VISION_MODEL=
GLM_EMBEDDING_MODEL=
GLM_IMAGE_GEN_MODEL=
KIMI_MODEL=kimi-k2.6
KIMI_EMBEDDING_MODEL=
KIMI_IMAGE_GEN_MODEL=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_EMBEDDING_MODEL=
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_EMBEDDING_MODEL=
MINIMAX_IMAGE_GEN_MODEL=

# Query loop and LLM defaults
TINYSOUL_MAX_TURNS=20
TINYSOUL_TEMPERATURE=0.7
TINYSOUL_MAX_TOKENS=8000
TINYSOUL_MAX_RETRIES=3
TINYSOUL_BASE_RETRY_DELAY=1.0
TINYSOUL_LLM_TIMEOUT=120.0

# Action execution budgets
TINYSOUL_ACTION_TIMEOUT=120.0
TINYSOUL_CLI_TIMEOUT=60.0
TINYSOUL_SCRIPT_TIMEOUT=15.0
TINYSOUL_PARALLEL_DISPATCH_BUFFER=20.0
TINYSOUL_PARALLEL_MAX_WORKERS=5

# Prompt/context compaction
TINYSOUL_REFERENCE_TRUNCATE=8000
TINYSOUL_CONTENT_TRUNCATE=16000
TINYSOUL_COMPACT_MAX_RECORDS=10
TINYSOUL_COMPACT_MAX_ERRORS=5
TINYSOUL_COMPACT_MAX_LOGS=3

# Logging
TINYSOUL_LOG_LEVEL=verbose
TINYSOUL_LOG_CATEGORIES=all
TINYSOUL_LOG_COLOR=1

# Real API tests are skipped unless enabled.
RUN_REAL_API_TESTS=0

# Advanced: override complete chat profiles as JSON.
# TINYSOUL_CHAT_PROFILES={"step1":{"provider_chain":["deepseek","kimi"],"required_capabilities":["text"],"preferred_capabilities":[],"chat_model_overrides":{},"config":{}},"step2":{"provider_chain":["zhipu","kimi"],"required_capabilities":["text"],"preferred_capabilities":[],"chat_model_overrides":{},"config":{}},"step3":{"provider_chain":["kimi","deepseek"],"required_capabilities":["text"],"preferred_capabilities":[],"chat_model_overrides":{},"config":{}},"action_llm":{"provider_chain":["kimi","zhipu"],"required_capabilities":["text"],"preferred_capabilities":["vision"],"chat_model_overrides":{},"config":{}}}
